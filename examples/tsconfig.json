{
	"compilerOptions": {
		"target": "ES2015",
		"module": "esNext",
		"moduleResolution": "bundler",
		"noImplicitAny": false,
		"sourceMap": true,
		"experimentalDecorators": true,
		"declaration": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"lib": [
			"ES2015",
			"es2020",
			"dom"
		],
		"types": [
			"@webgpu/types",
			"vite/client"
		]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts"
	]
}